#!/bin/bash
set -e

# Get list of staged files
staged=$(git diff --cached --name-only)

# Check if README.md or README.Rmd are staged
has_readme_rmd=false
has_readme_md=false

while read -r file; do
  if [[ "$file" == "README.Rmd" ]]; then
    has_readme_rmd=true
  elif [[ "$file" == "README.md" ]]; then
    has_readme_md=true
  fi
done <<< "$staged"

# If neither is staged, we are good to go
if [ "$has_readme_rmd" = false ] && [ "$has_readme_md" = false ]; then
  exit 0
fi

msg="use 'git commit --no-verify' to override this check"

# Check if README.Rmd is newer than README.md
if [ -f "README.Rmd" ] && [ -f "README.md" ]; then
  if [ "README.Rmd" -nt "README.md" ]; then
    echo "README.md is out of date; please re-knit README.Rmd"
    echo "$msg"
    exit 1
  fi
fi

# Check if both are staged
if [ "$has_readme_rmd" = true ] && [ "$has_readme_md" = false ]; then
  echo "README.Rmd and README.md should be both staged"
  echo "$msg"
  exit 1
fi

if [ "$has_readme_rmd" = false ] && [ "$has_readme_md" = true ]; then
  echo "README.Rmd and README.md should be both staged"
  echo "$msg"
  exit 1
fi

exit 0
